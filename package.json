{
  "name": "mixid",
  "version": "1.0.0",
  "description": "A simple random ID generator based on inputed data",
  "license": "MIT",
  "author": "IEatUranium238",
  "repository": "https://github.com/IEatUranium238/mixid",
  "readme": "https://github.com/IEatUranium238/mixid/blob/main/README.md",
  "type": "module",
  "main": "mixid.ts",
  "files": [
    "/build"
  ],
  "scripts": {
    "tsc": "tsc",
    "build:esm": "esbuild src/mixid.ts --bundle --minify --outfile=build/mixid.js --format=esm --platform=neutral --target=esnext --keep-names",
    "build": "npm run tsc && npm run build:esm",
    "test": "vitest --coverage",
    "publish": "npm run build && npm publish"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
